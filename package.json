{
  "name": "copilotx",
  "version": "4.0.0-alpha.0",
  "description": "GitHub Copilot API proxy for OpenAI, Responses, and Anthropic-compatible clients",
  "license": "MIT",
  "bin": {
    "copilotx": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "drizzle",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "postinstall": "bun run tools/patch-effect-native-bun-test.ts",
    "clean": "rm -rf dist coverage .knip-tmp",
    "build": "bun run clean && rslib build",
    "inspect": "rslib inspect",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint --config .oxlintrc.json --tsconfig tsconfig.json --type-aware --import-plugin --promise-plugin --deny-warnings src rslib.config.ts drizzle.config.ts",
    "lint:fix": "oxlint --config .oxlintrc.json --tsconfig tsconfig.json --type-aware --import-plugin --promise-plugin --fix --fix-suggestions src rslib.config.ts drizzle.config.ts",
    "test": "bun test",
    "check": "bun run typecheck && bun run fmt:check && bun run lint && bun run test",
    "serve": "bun run src/bin/cli.ts serve",
    "dev": "bun run src/bin/cli.ts serve --host 127.0.0.1 --port 24680",
    "auth:login": "bun run src/bin/cli.ts auth login",
    "models": "bun run src/bin/cli.ts models",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "publint": "publint",
    "knip": "knip",
    "jscpd": "jscpd --config .jscpd.json"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.31",
    "@effect/sql-pg": "4.0.0-beta.31",
    "drizzle-orm": "1.0.0-beta.17-67b1795",
    "effect": "4.0.0-beta.31",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@effect-native/bun-test": "4.0.0",
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-type-check": "^1.3.4",
    "@rslib/core": "^0.20.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "1.0.0-beta.17-67b1795",
    "jscpd": "^4.0.5",
    "knip": "^5.64.1",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.16.0",
    "publint": "^0.3.18",
    "rsbuild-plugin-publint": "^0.3.4",
    "typescript": "6.0.1-rc",
    "ultracite": "^7.3.0"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "packageManager": "bun@1.3.10"
}
