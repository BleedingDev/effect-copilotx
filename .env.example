# `mise run start` will create `.env` from this file and generate
# `COPILOTX_TOKEN_ENCRYPTION_KEY` automatically if it is blank.

# Local development defaults
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/effect_copilotx_dev
COPILOTX_HOST=127.0.0.1
COPILOTX_PORT=24680
COPILOTX_API_KEY=
COPILOTX_CORS_ORIGINS=http://127.0.0.1:1111,http://localhost:1111
COPILOTX_FORCE_MODELS=
COPILOTX_GITHUB_BILLING_TOKEN=
COPILOTX_TOKEN_ENCRYPTION_KEY=
COPILOTX_LOG_LEVEL=info
